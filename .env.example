# -----------------------------------------------------------------------------
# Database (required for Prisma migrate / seed / runtime API)
# Copy to `.env` and fill in real values. Never commit `.env`.
# https://www.prisma.io/docs/orm/reference/connection-urls
# -----------------------------------------------------------------------------
#
# Supabase Postgres connection strings:
# - `DATABASE_URL` should be the *pooled* connection string (PgBouncer / connection pooling).
# - `DIRECT_URL` should be the *direct* connection string (used by Prisma for migrations/admin tasks).
#
# Paste the exact URLs from your Supabase Dashboard -> Project Settings -> Database -> Connection string.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.ltpsgrkluirbkontprqg.supabase.co:5432/postgres?sslmode=require&pgbouncer=true"

# Optional: direct (non-pooled) URL for migrations when using PgBouncer / serverless
# providers (Neon, Supabase, etc.). Uncomment only if your host requires it.
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.ltpsgrkluirbkontprqg.supabase.co:5432/postgres?sslmode=require"

# -----------------------------------------------------------------------------
# App / Next.js + Auth.js (NextAuth v5)
# -----------------------------------------------------------------------------
NODE_ENV=development

# Set to 1 to log dashboard bundle timings and JSON payload sizes (server stdout only).
# DASHBOARD_PERF_LOG=1

# Required for JWT signing (middleware + Credentials session). Generate e.g. `openssl rand -base64 32`
AUTH_SECRET="replace-with-a-long-random-string"

# Local dev: allow non-TLS localhost (set true in production behind HTTPS only as appropriate)
AUTH_TRUST_HOST=true

# Optional: force session cookie naming for middleware JWT read. Leave unset: inferred from
# `x-forwarded-proto` or request URL (fixes `next start` on http://localhost vs production HTTPS).
# AUTH_COOKIE_SECURE=true

# Demo seed password for all seeded users (override in real environments)
# SEED_USER_PASSWORD="your-secure-demo-password"

# -----------------------------------------------------------------------------
# One-off: clear app data (see prisma/clear-data.ts). Never set in production.
# Run: CONFIRM_CLEAR_DATA=true npm run db:clear
# -----------------------------------------------------------------------------
# CONFIRM_CLEAR_DATA=true
